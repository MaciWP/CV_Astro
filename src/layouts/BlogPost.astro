---
/**
 * Blog post layout — wraps Layout.astro with reading-optimized typography,
 * BlogPosting JSON-LD + per-post hreflang (injected into <head> via Layout's
 * `head` slot), a localized "Back to blog" link, and lazy theme-aware Giscus.
 * Multilingual: `lang` localizes the chrome; `translations` lists the locales
 * that actually have this post (drives correct, 404-free hreflang).
 * @file src/layouts/BlogPost.astro
 */
import Layout from './Layout.astro';
import Giscus from '../components/Giscus.astro';
import { blogUrl } from '../utils/blog';

export interface Props {
  lang: string;
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  /** Slug WITHOUT locale prefix — the /blog/<slug> segment. */
  slug: string;
  heroImage?: string;
  heroImageAlt?: string;
  /** Locales (en/es/fr/de) that have a published version of this slug. */
  translations?: string[];
}

const {
  lang,
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  slug,
  heroImage,
  heroImageAlt,
  translations = [lang],
} = Astro.props;

const SITE = 'https://oriolmacias.dev';
const canonical = `${SITE}${blogUrl(lang, slug)}`;

// Localized UI chrome.
const STRINGS: Record<string, { back: string; updated: string; tags: string }> = {
  en: { back: 'Back to blog', updated: 'Updated', tags: 'Tags' },
  es: { back: 'Volver al blog', updated: 'Actualizado', tags: 'Etiquetas' },
  fr: { back: 'Retour au blog', updated: 'Mis à jour', tags: 'Tags' },
  de: { back: 'Zurück zum Blog', updated: 'Aktualisiert', tags: 'Tags' },
};
const DATE_LOCALE: Record<string, string> = { en: 'en-GB', es: 'es-ES', fr: 'fr-FR', de: 'de-DE' };
const t = STRINGS[lang] ?? STRINGS.en;

// Deterministic at build time (formats the fixed frontmatter date, not "now").
const fmt = new Intl.DateTimeFormat(DATE_LOCALE[lang] ?? 'en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const displayDate = fmt.format(pubDate);
const displayUpdated = updatedDate ? fmt.format(updatedDate) : null;

const backHref = lang === 'en' ? '/blog' : `/${lang}/blog`;

// BlogPosting structured data (author "Oriol Macias", per the SEO brief).
const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Person', name: 'Oriol Macias', url: SITE },
  publisher: { '@type': 'Person', name: 'Oriol Macias', url: SITE },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  image: `${SITE}/images/oriol_macias-1280.jpg`,
  url: canonical,
  inLanguage: lang,
};

// Per-post hreflang: only locales that actually have this post (no 404s).
// x-default points to en when available, else the first existing locale.
const emitHreflang = translations.length > 1;
const xDefaultLang = translations.includes('en') ? 'en' : translations[0];
---

<Layout
  title={`${title} — Oriol Macias`}
  description={description}
  lang={lang}
  canonicalUrl={canonical}
  ogType="article"
>
  <Fragment slot="head">
    <Fragment
      set:html={`<script type="application/ld+json">${JSON.stringify(blogPostingSchema)}</script>`}
    />
    {
      emitHreflang && (
        <Fragment>
          {translations.map((loc) => (
            <link rel="alternate" hreflang={loc} href={`${SITE}${blogUrl(loc, slug)}`} />
          ))}
          <link rel="alternate" hreflang="x-default" href={`${SITE}${blogUrl(xDefaultLang, slug)}`} />
        </Fragment>
      )
    }
  </Fragment>

  <article class="blog-post mx-auto">
    <a
      href={backHref}
      class="inline-flex items-center gap-1 text-sm font-medium text-accessible-brand-red hover:underline mb-8"
    >
      <span aria-hidden="true">←</span> {t.back}
    </a>

    {
      heroImage && (
        <img
          src={heroImage}
          alt={heroImageAlt ?? ''}
          width="1200"
          height="400"
          loading="eager"
          class="w-full h-auto mb-8 rounded-none border border-light-border dark:border-dark-border bg-light-surface dark:bg-dark-surface"
        />
      )
    }

    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3">{title}</h1>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-light-text-secondary dark:text-dark-text-secondary">
        <time datetime={pubDate.toISOString()}>{displayDate}</time>
        {displayUpdated && <span>· {t.updated} {displayUpdated}</span>}
        {
          tags.length > 0 && (
            <ul class="flex flex-wrap gap-2" aria-label={t.tags}>
              {tags.map((tag) => (
                <li class="px-2 py-1 text-xs font-medium bg-brand-red/10 text-brand-red dark:bg-brand-red/20 dark:text-red-300 border border-brand-red/20 rounded-none">
                  {tag}
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </header>

    <div class="post-prose">
      <slot />
    </div>

    <Giscus />
  </article>
</Layout>

<style>
  /* Reading column: ~65ch, comfortable line-height, site fonts, dark/light. */
  .blog-post {
    max-width: 65ch;
  }

  .post-prose {
    line-height: 1.65;
    color: #1f2937; /* light-text */
    font-size: 1.0625rem;
  }
  :global(.dark) .post-prose {
    color: #f9fafb; /* dark-text */
  }

  /* Headings — Outfit via the global h1–h6 rule; spacing tuned for prose. */
  .post-prose :global(h2) {
    font-size: 1.6rem;
    font-weight: 600;
    margin: 2.5rem 0 0.75rem;
    line-height: 1.25;
  }
  .post-prose :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 1.75rem 0 0.5rem;
    line-height: 1.3;
  }
  .post-prose :global(p) {
    margin: 0 0 1.25rem;
  }
  .post-prose :global(ul),
  .post-prose :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }
  .post-prose :global(ul) {
    list-style: disc;
  }
  .post-prose :global(ol) {
    list-style: decimal;
  }
  .post-prose :global(li) {
    margin-bottom: 0.4rem;
  }
  .post-prose :global(li::marker) {
    color: #d83333; /* brand-red bullets */
  }
  .post-prose :global(a) {
    color: #991b1b; /* accessible red, light */
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  :global(.dark) .post-prose :global(a) {
    color: #fca5a5; /* accessible red, dark */
  }
  /* Inline code */
  .post-prose :global(:not(pre) > code) {
    background: #f3f4f6;
    padding: 0.15em 0.4em;
    font-size: 0.9em;
    border-radius: 0; /* sharp corners */
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  :global(.dark) .post-prose :global(:not(pre) > code) {
    background: #1e2433;
  }
  /* Shiki code blocks (.astro-code carries an inline background from the theme) */
  .post-prose :global(pre) {
    padding: 1rem 1.25rem;
    margin: 0 0 1.5rem;
    overflow-x: auto;
    border: 1px solid #374151;
    border-radius: 0; /* sharp corners */
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .post-prose :global(blockquote) {
    border-left: 3px solid #d83333;
    padding-left: 1rem;
    margin: 0 0 1.25rem;
    color: #5f6772;
    font-style: italic;
  }
  :global(.dark) .post-prose :global(blockquote) {
    color: #9ca3af;
  }
  .post-prose :global(hr) {
    border: 0;
    border-top: 1px solid #d1d5db;
    margin: 2.5rem 0;
  }
  :global(.dark) .post-prose :global(hr) {
    border-top-color: #374151;
  }
  .post-prose :global(img) {
    max-width: 100%;
    height: auto;
  }
  .post-prose :global(strong) {
    font-weight: 600;
  }
</style>
