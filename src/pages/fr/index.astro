---
import Layout from "../../layouts/Layout.astro";

// Import CV components - All pure Astro now (no React)
import ProfileHeader from "../../components/cv/ProfileHeader.astro";
import Experience from "../../components/cv/Experience.astro";
import Skills from "../../components/cv/Skills.astro";
import Languages from "../../components/cv/Languages.astro";
import Education from "../../components/cv/Education.astro";
import Projects from "../../components/cv/Projects.astro";
import ExpertiseSummary from "../../components/cv/ExpertiseSummary.astro";
import FAQSchema from "../../components/FAQSchema.astro";

// Enhanced metadata for SEO (French version)
const pageTitle = "Oriol Macias - Portfolio de Développeur Logiciel";
const pageDescription =
    "CV et portfolio professionnel d'Oriol Macias, Développeur Backend avec plus de 8 ans d'expérience en intégration de protocoles industriels (SNMP, Modbus, BACnet) et infrastructure de centres de données.";
const ogImage = "/images/oriol_macias-1280.jpg";
const canonicalUrl = "https://oriolmacias.dev/fr";

// FAQs for rich snippets
const faqs = [
  {
    question: "Avez-vous un permis de travail pour la Suisse ?",
    answer: "En tant que citoyen de l'UE (Espagne), je suis éligible à un permis de travail suisse (Permis B) immédiatement après l'embauche via les Accords Bilatéraux CH-UE. Aucun parrainage de visa requis."
  },
  {
    question: "Dans quels langages de programmation êtes-vous spécialisé ?",
    answer: "Je me spécialise en Python et C#, avec une vaste expérience en Django, .NET Framework et Core, et développement d'API REST."
  },
  {
    question: "Avec quels protocoles industriels travaillez-vous ?",
    answer: "J'ai plus de 8 ans d'expérience dans l'intégration des protocoles SNMP, Modbus et BACnet pour les plateformes DCIM."
  },
  {
    question: "Êtes-vous disponible pour le travail à distance ?",
    answer: "Oui, je suis ouvert aux postes à distance, hybrides ou sur site en Suisse (Zurich, Bâle, Genève, Lausanne) ou en Espagne."
  },
  {
    question: "Quel est votre préavis ?",
    answer: "J'ai un préavis de 2 semaines et je peux commencer peu après."
  }
];
---

<Layout
    title={pageTitle}
    description={pageDescription}
    lang="fr"
    ogImage={ogImage}
    canonicalUrl={canonicalUrl}
>
    <div
        id="cv-person"
        class="space-y-12"
        itemscope
        itemtype="https://schema.org/Person"
    >
        {/* ProfileHeader - SSG Optimized */}
        <div class="-mb-8">
            <ProfileHeader lang="fr" />
        </div>

        {/* Expertise Summary - Key competencies */}
        <ExpertiseSummary lang="fr" />

        {/* Experience - Pure Astro */}
        <Experience lang="fr" />

        {/* Skills */}
        <Skills lang="fr" />

        {/* Education */}
        <Education lang="fr" />

        {/* Languages - Pure Astro */}
        <Languages lang="fr" />

        {/* Projects - Pure Astro */}
        <Projects lang="fr" />

        {/* Regional profiles - internal links for market pages */}
        <nav
            class="text-sm text-gray-700 dark:text-gray-300"
            aria-label="Profils régionaux"
        >
            Vous recrutez sur un marché précis ?
            <a href="/switzerland" class="text-brand-red hover:underline font-semibold">Suisse</a> :
            <a href="/switzerland#zurich" class="text-brand-red hover:underline">Zurich</a>,
            <a href="/switzerland#geneva" class="text-brand-red hover:underline">Genève</a>,
            <a href="/switzerland#basel" class="text-brand-red hover:underline">Bâle</a>,
            <a href="/switzerland#lausanne" class="text-brand-red hover:underline">Lausanne</a>
            <span aria-hidden="true"> · </span>
            <a href="/spain" class="text-brand-red hover:underline font-semibold">Espagne</a> :
            <a href="/spain#madrid" class="text-brand-red hover:underline">Madrid</a>,
            <a href="/spain#barcelona" class="text-brand-red hover:underline">Barcelone</a>
        </nav>

        {/* FAQ Section with structured data */}
        <FAQSchema faqs={faqs} lang="fr" />

        {/* SEO hidden content */}
        <div class="sr-only">
            <div itemprop="name">Oriol Macias</div>
            <div itemprop="jobTitle">Développeur Backend Senior</div>
            <div itemprop="description">
                Développeur Backend axé sur les solutions, spécialisé dans
                l'intégration de protocoles industriels (SNMP, Modbus, BACnet)
                avec plus de 8 ans d'expérience dans les applications à haute
                performance.
            </div>
            <div itemprop="email">oriolomb@gmail.com</div>
            <a itemprop="url" href="https://oriolmacias.dev"
                >https://oriolmacias.dev</a
            >
            <a itemprop="sameAs" href="https://github.com/MaciWP">GitHub</a>
            <a
                itemprop="sameAs"
                href="https://linkedin.com/in/oriolmaciasbadosa">LinkedIn</a
            >
        </div>
    </div>
</Layout>
