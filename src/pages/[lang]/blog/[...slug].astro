---
/**
 * Blog post page for non-default locales — /es|/fr|/de/blog/<slug>.
 * Per the Astro i18n recipe: posts live in blog/<lang>/, so the entry id is
 * "<lang>/<slug>"; split it to derive params.
 * @file src/pages/[lang]/blog/[...slug].astro
 */
import { getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';
import { localeOf, slugFromId, localesForSlug, localizedPosts, BLOG_LOCALES } from '../../../utils/blog';

export async function getStaticPaths() {
  const all = await getCollection('blog');
  // Non-default locales only; en is served by src/pages/blog/[...slug].astro.
  // localizedPosts() reuses the shared draft-visibility rule (no inline duplicate).
  return BLOG_LOCALES.filter((l) => l !== 'en').flatMap((lang) =>
    localizedPosts(all, lang).map((post) => {
      const slug = slugFromId(post.id);
      return { params: { lang, slug }, props: { post, translations: localesForSlug(all, slug) } };
    }),
  );
}

const { post, translations } = Astro.props;
const lang = localeOf(post.id);
const { Content } = await render(post);
---

<BlogPost
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  slug={slugFromId(post.id)}
  heroImage={post.data.heroImage}
  heroImageAlt={post.data.heroImageAlt}
  translations={translations}
>
  <Content />
</BlogPost>
