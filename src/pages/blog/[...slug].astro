---
/**
 * Blog post page (English, default locale) — /blog/<slug>.
 * Renders en/ posts; drafts excluded from production builds.
 * @file src/pages/blog/[...slug].astro
 */
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { localizedPosts, slugFromId, localesForSlug } from '../../utils/blog';

export async function getStaticPaths() {
  const all = await getCollection('blog');
  return localizedPosts(all, 'en').map((post) => {
    const slug = slugFromId(post.id);
    return { params: { slug }, props: { post, translations: localesForSlug(all, slug) } };
  });
}

const { post, translations } = Astro.props;
const { Content } = await render(post);
---

<BlogPost
  lang="en"
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  slug={slugFromId(post.id)}
  heroImage={post.data.heroImage}
  heroImageAlt={post.data.heroImageAlt}
  translations={translations}
>
  <Content />
</BlogPost>
