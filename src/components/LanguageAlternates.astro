---
/**
 * Language alternates component for SEO - Pure Astro (no client JS)
 * Generates hreflang tags at build time, eliminating React hydration overhead
 * @file src/components/LanguageAlternates.astro
 */

import { normalizePathname } from '../utils/seo';

interface Props {
    currentLang?: string;
    currentPath?: string;
}

const { currentLang = 'en', currentPath = '/' } = Astro.props;

// Website base URL
const baseUrl = 'https://oriolmacias.dev';

// Normalize the path (ensure it starts with /)
const normalizedPath = currentPath.startsWith('/') ? currentPath : `/${currentPath}`;

// Language-NEUTRAL logical path: strip .html build artifacts and any language
// prefix, so each alternate is built from the same logical page
// ('/es' -> '/', '/es/foo' -> '/foo'); prevents URLs like '/es/es.html'
const logicalPath =
    normalizePathname(normalizedPath).replace(/^\/(es|fr|de)(?=\/|$)/, '') || '/';

// Language variants available on the site
const languages = [
    { code: 'en', hreflang: 'en', region: 'en-US', name: 'English' },
    { code: 'es', hreflang: 'es', region: 'es-ES', name: 'Español' },
    { code: 'fr', hreflang: 'fr', region: 'fr-CH', name: 'Français' },
    { code: 'de', hreflang: 'de', region: 'de-CH', name: 'Deutsch' }
];

// Generate URLs for each language from the logical path
// (en root keeps its trailing slash to match canonical + sitemap form)
const languageUrls = languages.map(lang => {
    const url = lang.code === 'en'
        ? `${baseUrl}${logicalPath === '/' ? '/' : logicalPath}`
        : `${baseUrl}/${lang.code}${logicalPath === '/' ? '' : logicalPath}`;

    return {
        ...lang,
        url
    };
});
---

{/* Standard hreflang tags */}
{languageUrls.map(lang => (
    <link
        rel="alternate"
        hreflang={lang.hreflang}
        href={lang.url}
    />
))}

{/* Region-specific hreflang tags for better targeting */}
{languageUrls.map(lang => (
    <link
        rel="alternate"
        hreflang={lang.region}
        href={lang.url}
    />
))}

{/* x-default hreflang for language negotiation */}
<link
    rel="alternate"
    hreflang="x-default"
    href={languageUrls.find(lang => lang.code === 'en')?.url || baseUrl}
/>

{/* Language metadata for Search Engines and browsers */}
<meta http-equiv="content-language" content={currentLang} />
