{
  "name": "oriol-macias-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal CV & portfolio of Oriol Macias — Senior Backend Developer. Astro static site with 4-language i18n (en/es/fr/de), Tailwind, and no runtime JS framework.",
  "author": "Oriol Macias <oriolomb@gmail.com>",
  "license": "MIT",
  "homepage": "https://oriolmacias.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaciWP/CV_Astro.git"
  },
  "keywords": [
    "astro",
    "portfolio",
    "cv",
    "resume",
    "tailwindcss",
    "i18n",
    "static-site",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "generate-images": "node scripts/generate-profile-images.js",
    "dev": "node scripts/dev.js && pnpm run generate-images",
    "build": "node scripts/build.js && pnpm run generate-images",
    "preview": "astro preview",
    "check": "pnpm run check:contrast && pnpm run check:translations && pnpm run check:structured-data",
    "check:contrast": "node scripts/check-contrast.js",
    "check:translations": "node scripts/check-translations.js",
    "check:structured-data": "node scripts/validate-structured-data.js",
    "a11y": "pnpm run check:contrast",
    "a11y:audit": "lighthouse http://localhost:4321 --output-path=./lighthouse-report.html --view --chrome-flags=\"--headless\" --only-categories=accessibility",
    "clean": "rimraf dist .astro",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@playform/compress": "^0.2.3",
    "astro": "^6.4.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "rimraf": "^6.1.3",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "wcag-contrast": "^3.0.0"
  }
}
